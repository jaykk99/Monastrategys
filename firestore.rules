rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: {userId}
    // Fields:
    //   - uid: string (required)
    //   - email: string (required)
    //   - role: string (required, 'admin' | 'user')
    //   - plan: string (required, 'STARTER' | 'BASIC' | 'PRO')
    //   - unlockedStrats: list of strings (required)
    //   - createdAt: timestamp (required)
    //
    // Collection: strategies
    // Document ID: {strategyId}
    // Fields:
    //   - id: string (required)
    //   - name: string (required)
    //   - description: string (required)
    //   - tier: string (required, 'STARTER' | 'BASIC' | 'PRO')
    //   - code: string (required)
    //   - createdAt: timestamp (required)
    //
    // Collection: payment_verifications
    // Document ID: {verificationId}
    // Fields:
    //   - userId: string (required)
    //   - txHash: string (required)
    //   - planRequested: string (required, 'BASIC' | 'PRO')
    //   - status: string (required, 'pending' | 'verified' | 'rejected')
    //   - timestamp: timestamp (required)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() && (
        (request.auth.token.email == "jayomer1234@gmail.com" && request.auth.token.email_verified == true)
      );
    }

    function hasOnlyAllowedFields(allowedFields) {
      return request.resource.data.keys().hasOnly(allowedFields);
    }

    function hasRequiredFields(requiredFields) {
      return request.resource.data.keys().hasAll(requiredFields);
    }

    function uidUnchanged() {
      return !('uid' in request.resource.data) || request.resource.data.uid == request.auth.uid;
    }

    function uidNotModified() {
      return !('uid' in request.resource.data) || request.resource.data.uid == resource.data.uid;
    }

    // ===============================================================
    // Domain Validators
    // ===============================================================

    function isValidUser(data) {
      return hasRequiredFields(['uid', 'email', 'role', 'plan', 'unlockedStrats', 'createdAt']) &&
             hasOnlyAllowedFields(['uid', 'email', 'role', 'plan', 'unlockedStrats', 'createdAt', 'expiresAt', 'backtestCount']) &&
             data.uid is string && data.uid.size() > 0 && data.uid.size() < 100 &&
             data.email is string && data.email.size() > 0 && data.email.size() < 100 &&
             data.role in ['admin', 'user'] &&
             data.plan in ['STARTER', 'BASIC', 'PRO'] &&
             data.unlockedStrats is list && data.unlockedStrats.size() <= 100 &&
             data.createdAt is timestamp &&
             (!('expiresAt' in data) || data.expiresAt == null || data.expiresAt is timestamp) &&
             (!('backtestCount' in data) || data.backtestCount is number);
    }

    function isValidStrategy(data) {
      return hasRequiredFields(['title', 'description', 'assetCategory', 'timeframes', 'content']) &&
             hasOnlyAllowedFields(['title', 'description', 'assetCategory', 'timeframes', 'content', 'author', 'timestamp', 'isAutoTrade', 'updatedAt']) &&
             data.title is string && data.title.size() > 0 && data.title.size() < 100 &&
             data.description is string && data.description.size() < 1000 &&
             data.assetCategory is string &&
             data.timeframes is list && data.timeframes.size() > 0 &&
             data.content is string && data.content.size() < 50000 &&
             (!('author' in data) || data.author is string) &&
             (!('timestamp' in data) || data.timestamp is timestamp) &&
             (!('isAutoTrade' in data) || data.isAutoTrade is bool) &&
             (!('updatedAt' in data) || data.updatedAt is timestamp);
    }

    function isValidPaymentVerification(data) {
      return hasRequiredFields(['userId', 'txHash', 'plan', 'status', 'timestamp', 'amount', 'currency', 'email']) &&
             hasOnlyAllowedFields(['userId', 'txHash', 'plan', 'status', 'timestamp', 'amount', 'currency', 'email']) &&
             data.userId is string && data.userId.size() > 0 && data.userId.size() < 100 &&
             data.txHash is string && data.txHash.size() > 0 && data.txHash.size() < 150 &&
             data.plan in ['Starter', 'Basic', 'Pro', 'STARTER', 'BASIC', 'PRO'] &&
             data.status in ['pending', 'verified', 'rejected'] &&
             data.timestamp is timestamp &&
             data.amount is string &&
             data.currency is string &&
             data.email is string;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /artifacts/{appId}/public/data {
      match /users/{userId} {
        allow read: if isOwner(userId) || isAdmin();
        
        allow create: if isAuthenticated() && isValidUser(request.resource.data) && (
          isAdmin() || (
            isOwner(userId) &&
            request.resource.data.role == 'user' &&
            request.resource.data.plan == 'STARTER' &&
            request.resource.data.unlockedStrats.size() == 0 &&
            uidUnchanged()
          )
        );

        allow update: if isAuthenticated() && isValidUser(request.resource.data) && (
          isAdmin() || (
            isOwner(userId) &&
            uidNotModified() &&
            request.resource.data.role == resource.data.role &&
            request.resource.data.email == resource.data.email &&
            request.resource.data.createdAt == resource.data.createdAt &&
            (
              // STARTER can have up to 1 strategy
              (request.resource.data.plan == 'STARTER' && request.resource.data.unlockedStrats.size() <= 1) ||
              // BASIC can have up to 3 strategies
              (request.resource.data.plan == 'BASIC' && request.resource.data.unlockedStrats.size() <= 3) ||
              // PRO can have unlimited (up to 100 limit in validator)
              (request.resource.data.plan == 'PRO')
            )
          )
        );
      }

      match /global_strategies/{strategyId} {
        // Any authenticated user can read strategies (to see what's available)
        allow read: if isAuthenticated();
        allow create, update: if isAdmin() && isValidStrategy(request.resource.data);
        allow delete: if isAdmin();
      }

      match /payment_verifications/{verificationId} {
        allow read: if isAuthenticated() && (request.auth.uid == resource.data.userId || isAdmin());
        
        allow create: if isAuthenticated() && isValidPaymentVerification(request.resource.data) && (
          isAdmin() || (
            request.auth.uid == request.resource.data.userId &&
            (request.resource.data.status == 'pending' || request.resource.data.status == 'verified')
          )
        );

        allow update: if isAdmin() && isValidPaymentVerification(request.resource.data);
      }

      match /api_keys/{userId} {
        allow read, write: if isOwner(userId);
      }

      match /exchange_keys/{userId} {
        allow read, write: if isOwner(userId);
      }
    }
  }
}
